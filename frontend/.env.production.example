# Plantilla de entorno para el build de PRODUCCIÓN del frontend (Vite).
#
# No se usa automáticamente: copiar como `.env.production` (Vite lo carga
# solo al correr `npm run build`, sin afectar `npm run dev` en local) y
# reemplazar los valores con el dominio real del backend desplegado.

VITE_BACKEND_URL=https://<dominio-real-del-backend>
VITE_API_URL=https://<dominio-real-del-backend>/api
