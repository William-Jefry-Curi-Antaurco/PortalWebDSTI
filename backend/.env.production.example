# Plantilla de entorno para PRODUCCIÓN.
#
# Este archivo NO se usa automáticamente: es una referencia para cuando se
# despliegue el portal. El .env local (desarrollo en Laragon) sigue intacto
# con APP_ENV=local. Antes de desplegar:
#   1. Copiar este archivo como `.env` en el servidor de producción.
#   2. Reemplazar TODOS los valores marcados con <...>.
#   3. Generar una APP_KEY nueva y exclusiva para producción con:
#        php artisan key:generate
#      (nunca reutilizar la APP_KEY de desarrollo/staging).
#   4. Ejecutar: php artisan config:cache && php artisan route:cache
#      && php artisan storage:link && php artisan migrate --force

APP_NAME="Portal DSTI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://<dominio-real-del-backend>

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# En producción no queremos trazas de error detalladas en pantalla (APP_DEBUG=false
# ya cubre eso), pero sí conservar los logs con nivel moderado, no "debug".
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=<host-bd-produccion>
DB_PORT=3306
DB_DATABASE=<nombre-bd-produccion>
DB_USERNAME=<usuario-bd-produccion>
DB_PASSWORD=<password-bd-produccion>

SESSION_DRIVER=database
SESSION_LIFETIME=120
# HTTPS obligatorio en producción: la cookie de sesión solo debe viajar por
# conexiones cifradas.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=<dominio-real-sin-protocolo>
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Reemplazar por un proveedor SMTP real (no "log") para que la mesa de ayuda
# y las notificaciones lleguen de verdad.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=<host-smtp>
MAIL_PORT=587
MAIL_USERNAME=<usuario-smtp>
MAIL_PASSWORD=<password-smtp>
MAIL_FROM_ADDRESS="soportecorreos@unasam.edu.pe"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Dominio real del frontend desplegado (sin barra final).
FRONTEND_URL=https://<dominio-real-del-frontend>
SANCTUM_STATEFUL_DOMAINS=<dominio-real-del-frontend-sin-protocolo>
SESSION_DOMAIN=<dominio-real-sin-protocolo>
# Mismo dominio que FRONTEND_URL. Si hay más de un origen real (ej. www y
# sin www), separarlos por comas.
CORS_ALLOWED_ORIGINS=https://<dominio-real-del-frontend>
